@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

skinparam usecase {
  BackgroundColor AliceBlue
  BorderColor DarkSlateGray
  FontSize 12
}

skinparam actor {
  BackgroundColor LightYellow
  BorderColor DarkSlateGray
  FontSize 12
}

skinparam ArrowColor DarkSlateGray
skinparam ArrowFontSize 11

actor User as U
actor "Recruiter / Mentor" as R
actor "GitHub API" as G

rectangle "GitHub Activity Insight" {
  usecase "UC-01\nGitHub ID 입력" as UC1
  usecase "UC-02\n분석 요청 생성" as UC2
  usecase "UC-03\nGitHub 데이터 수집" as UC3
  usecase "UC-04\n지표 계산" as UC4
  usecase "UC-05\n점수/피드백 생성" as UC5
  usecase "UC-06\n결과 조회" as UC6
  usecase "UC-07\nPDF 리포트 다운로드" as UC7
  usecase "UC-08\n분석 이력 비교" as UC8
}

U --> UC1
U --> UC2
U --> UC6
U --> UC7
U --> UC8
R --> UC6
G --> UC3

UC2 ..> UC3 : <<include>>
UC3 ..> UC4 : <<include>>
UC4 ..> UC5 : <<include>>
UC7 ..> UC6 : <<extend>>
UC8 ..> UC6 : <<extend>>
@enduml