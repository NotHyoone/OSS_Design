# ========================================
# GitHub Activity Insight - 환경 변수 설정
# ========================================
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 설정하세요.

# ========================================
# 데이터베이스 설정
# ========================================
# PostgreSQL 호스트
DB_HOST=localhost

# PostgreSQL 포트
DB_PORT=5432

# 데이터베이스 이름
DB_NAME=insight

# 데이터베이스 사용자
DB_USER=insight_user

# 데이터베이스 암호
DB_PASSWORD=localdev123

# ========================================
# GitHub OAuth 2.0 설정
# ========================================
# GitHub에서 등록한 OAuth Application의 클라이언트 ID
GITHUB_OAUTH_CLIENT_ID=your_github_client_id

# GitHub에서 등록한 OAuth Application의 클라이언트 시크릿
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret

# OAuth 로그인 후 리다이렉트될 URI
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# ========================================
# GitHub Personal Access Token (선택사항)
# ========================================
# GitHub API 호출 시 사용할 Personal Access Token
# GitHub 설정 > Developer settings > Personal access tokens에서 생성
GITHUB_TOKEN=

# ========================================
# 서버 설정
# ========================================
# 서버 포트
SERVER_PORT=8080

# ========================================
# 로깅 설정
# ========================================
# 로그 레벨 (INFO, DEBUG, WARN, ERROR)
LOG_LEVEL=DEBUG

# 로그 파일 경로
LOG_FILE_PATH=./logs/app.log
